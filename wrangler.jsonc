{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mcp-markdown-search",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-13",
  "observability": {
    "enabled": true,
  },
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "markdown-docs",
    },
  ],
  "ai": {
    "binding": "AI",
  },
  "env": {
    "preview": {
      "name": "mcp-markdown-search-preview",
    },
    "production": {
      "name": "mcp-markdown-search",
    },
  },
}
