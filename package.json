{
  "name": "mcp-markdown-search",
  "version": "0.0.1",
  "description": "MCP server for markdown search with full-text and semantic capabilities",
  "bin": {
    "mcp-markdown-search": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "wrangler dev",
    "dev:mcp": "bun --watch run src/mcp.ts",
    "cli": "bun run src/cli.ts",
    "deploy": "wrangler deploy --minify",
    "deploy:preview": "wrangler deploy --env preview",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit",
    "lint": "oxlint . --format=github",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "build": "bun build src/mcp.ts --compile --outfile dist/mcp-markdown-search",
    "build:cli": "bun build src/cli.ts --outfile dist/cli.js",
    "build:all": "bun run build && bun run build:cli",
    "publish:preview": "npx pkg-pr-new publish './dist/*' --no-compact --comment=update",
    "actions-up": "actions-up",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --format badge > .artifacts/fallow-health.svg"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "actions-up": "^1.14.3",
    "bun-types": "^1.3.14",
    "fallow": "^2.98.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.70.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.101.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run format:check && bun run typecheck"
  }
}
